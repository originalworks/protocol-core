{
    "name": "protocol-core-contracts",
    "version": "0.0.4",
    "scripts": {
        "lint": "eslint '**/*.{ts,mts}'",
        "lint:fix": "eslint '**/*.{ts,mts}' --fix",
        "typecheck": "tsc --noEmit",
        "release:contracts": "npm --prefix packages/contracts run release",
        "release:typechain": "npm --prefix packages/typechain run release",
        "release:hardhat": "npm --prefix packages/hardhat run release"
    },
    "devDependencies": {
        "@nomicfoundation/hardhat-foundry": "^1.1.3",
        "@nomicfoundation/hardhat-toolbox": "^5.0.0",
        "@nomicfoundation/hardhat-verify": "^2.0.14",
        "@openzeppelin/contracts": "^5.0.2",
        "@openzeppelin/contracts-upgradeable": "^5.1.0",
        "@openzeppelin/hardhat-upgrades": "^3.5.0",
        "@rumblefishdev/hardhat-kms-signer": "2.0.0",
        "dotenv": "16.4.5",
        "hardhat": "^2.22.18",
        "inquirer": "^13.4.1",
        "kzg-wasm": "^0.4.0",
        "semver": "^7.7.4",
        "@types/inquirer": "^9.0.9",
        "@types/semver": "^7.7.1"
    }
}